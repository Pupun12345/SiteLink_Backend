    {
      "name": "2. OTP Verification",
      "item": [
        {
          "name": "Verify OTP (Success)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"437208\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/verify-otp",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "verify-otp"]
            },
            "description": "Verify OTP received during registration. Use the OTP from registration response. Returns JWT token on success."
          },
          "response": []
        },
        {
          "name": "Verify OTP (Wrong - Test Attempts)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"000000\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/verify-otp",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "verify-otp"]
            },
            "description": "Test OTP attempt tracking. Try 3 times to see: 'Invalid OTP. 2 attempts remaining', then 'Maximum OTP attempts reached'"
          },
          "response": []
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/resend-otp",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "resend-otp"]
            },
            "description": "Resend OTP to phone number. Resets attempt counter and generates new OTP with fresh 10-minute expiration."
          },
          "response": []
        }
      ],
      "description": "OTP verification and resend functionality"
    },
    {
      "name": "3. Login",
