                  "description": "Full document content (can include HTML for formatting) (required)"
                },
                {
                  "key": "version",
                  "value": "1.0",
                  "type": "text",
                  "description": "Version number (optional, default: 1.0)"
                },
                {
                  "key": "effectiveDate",
                  "value": "2024-03-01T00:00:00.000Z",
                  "type": "text",
                  "description": "Effective date in ISO format (optional, default: current date)"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:5000/api/legal/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
