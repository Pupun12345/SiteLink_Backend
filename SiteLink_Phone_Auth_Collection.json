  "item": [
    {
      "name": "1. Registration Flow",
      "item": [
        {
          "name": "Register Customer (with Image)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Rajesh Kumar",
                  "type": "text",
                  "description": "User's full name (required)"
                },
                {
                  "key": "phone",
                  "value": "9876543210",
                  "type": "text",
                  "description": "10-digit phone number starting with 6-9 (required)"
                },
                {
                  "key": "password",
                  "value": "securePass123",
                  "type": "text",
                  "description": "Minimum 8 characters (required)"
                },
                {
                  "key": "confirmPassword",
                  "value": "securePass123",
                  "type": "text",
                  "description": "Must match password (required)"
                },
                {
                  "key": "userType",
                  "value": "customer",
                  "type": "text",
                  "description": "customer/vendor/worker (optional, default: customer)"
                },
                {
                  "key": "email",
                  "value": "rajesh.kumar@example.com",
                  "type": "text",
                  "description": "Email address (optional)"
                },
                {
                  "key": "profileImage",
                  "type": "file",
                  "src": "",
                  "description": "Image file: jpg/png/gif/webp, max 5MB (optional)"
                },
                {
                  "key": "aadhaarFrontImage",
                  "type": "file",
                  "src": "",
                  "description": "Aadhaar front side image (optional)"
                },
                {
                  "key": "aadhaarBackImage",
                  "type": "file",
                  "src": "",
                  "description": "Aadhaar back side image (optional)"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            },
            "description": "Register new customer with optional profile image. Returns OTP for verification. Note: Copy the OTP from response."
          },
          "response": []
        },
