                "type": "text",
                "description": "Admin JWT token"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "type",
                  "value": "privacy-policy",
                  "type": "text",
                  "description": "Document type: privacy-policy or terms-conditions (required)"
                },
                {
                  "key": "title",
                  "value": "Privacy Policy",
                  "type": "text",
                  "description": "Document title (required)"
                },
                {
                  "key": "content",
                  "value": "<h1>Privacy Policy</h1><p>We respect your privacy and are committed to protecting your personal information...</p><h2>Information We Collect</h2><p>- Personal identification information (Name, email, phone number, etc.)</p><p>- Usage data and analytics</p><h2>How We Use Your Information</h2><p>- To provide and maintain our service</p><p>- To notify you about changes to our service</p><p>- To provide customer support</p>",
