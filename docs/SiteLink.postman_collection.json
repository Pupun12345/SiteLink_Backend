            "url": { "raw": "{{baseUrl}}/api/profile/create/vendor", "host": ["{{baseUrl}}"], "path": ["api", "profile", "create", "vendor"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "companyName", "value": "BuildRight Pvt Ltd", "type": "text" },
                { "key": "name", "value": "Anil Shah", "type": "text" },
