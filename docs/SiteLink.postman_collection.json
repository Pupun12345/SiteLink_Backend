{
  "info": {
    "name": "SiteLink Backend API",
    "_postman_id": "b1f2c3d4-0000-4a00-9000-sitelink000001",
    "description": "Complete collection for the SiteLink Node/Express backend.\n\nHOW TO USE:\n1. Import this collection + the companion environment file (SiteLink.postman_environment.json).\n2. Select the 'SiteLink - Local' environment (top-right dropdown).\n3. Run `npm start` in the project so the API is live on {{baseUrl}}.\n4. Run Auth > Verify OTP (login) — dev OTP is always 123456. It auto-saves your JWT into {{token}}; every other request uses it automatically (collection-level Bearer auth).\n5. Requests that create a resource (Create Job, Create Post, Create Plan, Add Comment) auto-save its id (jobId/postId/planId/commentId) via a test script, so the like/comment/edit/delete requests below them work out of the box.\n\nAll previously reported bugs are fixed as of this version: amenities router is mounted and its controller no longer throws, Plans/Notifications-send are admin-only, Save FCM Token uses the logged-in user automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "phone", "value": "9876543210", "type": "string" },
    { "key": "postId", "value": "", "type": "string" },
    { "key": "jobId", "value": "", "type": "string" },
    { "key": "commentId", "value": "", "type": "string" },
    { "key": "planId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register (request OTP)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{phone}}\"\n}" },
            "description": "Public. Creates/updates a user and issues a 6-digit OTP. In non-production NODE_ENV the OTP is always `123456`."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "POST", "url": { "raw": "{{baseUrl}}/api/auth/register" } },
              "status": "OK", "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Registration successful. OTP sent to +919876543210\",\n  \"data\": { \"phone\": \"9876543210\", \"otp\": \"123456\", \"expiresIn\": \"10 minutes\" }\n}"
            }
          ]
        },
        {
          "name": "Verify OTP (login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  if (res.user && res.user.id) pm.collectionVariables.set('userId', res.user.id);",
                  "  pm.test('token stored', () => pm.expect(res.token).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "verify-otp"] },
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"otp\": \"123456\"\n}" },
            "description": "Public. Verifies OTP and returns a JWT. Run this first — it saves {{token}} automatically for every other request in this collection."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "POST", "url": { "raw": "{{baseUrl}}/api/auth/verify-otp" } },
              "status": "OK", "code": 200,
              "body": "{\n  \"success\": true,\n  \"token\": \"<jwt>\",\n  \"isExist\": false,\n  \"user\": { \"id\": \"...\", \"phone\": \"9876543210\", \"userType\": null, \"isPhoneVerified\": true }\n}"
            }
          ]
        },
        {
          "name": "Google Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/google-login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "google-login"] },
            "body": { "mode": "raw", "raw": "{\n  \"firebaseIdToken\": \"<firebase-RS256-id-token>\",\n  \"deviceToken\": \"<fcm-token>\",\n  \"deviceType\": \"android\"\n}" },
            "description": "Public. Verifies a Firebase Google ID token (RS256) and returns a JWT."
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] },
            "description": "Private. Returns the authenticated user document."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] },
            "description": "Private. Blacklists the current JWT until its TTL expires."
          }
        }
      ]
    },
    {
      "name": "2. Profile",
      "item": [
        {
          "name": "Get My Profile",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/profile/me", "host": ["{{baseUrl}}"], "path": ["api", "profile", "me"] } }
        },
        {
          "name": "Get States",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/profile/states", "host": ["{{baseUrl}}"], "path": ["api", "profile", "states"] } }
        },
        {
          "name": "Get Cities by State",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/profile/cities/14", "host": ["{{baseUrl}}"], "path": ["api", "profile", "cities", "14"] }, "description": "14 = Maharashtra. Change the id to any state id from Get States." }
        },
        {
          "name": "Get Skills",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/profile/skills", "host": ["{{baseUrl}}"], "path": ["api", "profile", "skills"] } }
