                { "key": "workArea", "value": "Mumbai Metro", "type": "text" },
                { "key": "workStateID", "value": "14", "type": "text" },
                { "key": "workCityID", "value": "1", "type": "text" },
                { "key": "panCardImage", "type": "file", "src": [] },
                { "key": "gstCertificate", "type": "file", "src": [] },
                { "key": "companyLogo", "type": "file", "src": [] },
                { "key": "profileImage", "type": "file", "src": [] }
              ]
            },
            "description": "Private. `panCardImage` and `gstCertificate` files are mandatory — attach files before sending."
          }
        },
        {
          "name": "Edit Worker Profile",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/profile/edit/worker", "host": ["{{baseUrl}}"], "path": ["api", "profile", "edit", "worker"] },
            "body": { "mode": "formdata", "formdata": [ { "key": "salary", "value": "1000", "type": "text" } ] },
            "description": "Only send the fields you want to change."
          }
        },
        {
          "name": "Edit Vendor Profile",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/profile/edit/vendor", "host": ["{{baseUrl}}"], "path": ["api", "profile", "edit", "vendor"] },
            "body": { "mode": "formdata", "formdata": [ { "key": "workArea", "value": "Pune", "type": "text" } ] },
            "description": "Only send the fields you want to change."
          }
        }
      ]
    },
    {
      "name": "3. Jobs",
      "item": [
        {
          "name": "Get Jobs (list/filter)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/jobs?location=Mumbai&search=mason&salaryType=daily&sort=highestSalary",
              "host": ["{{baseUrl}}"], "path": ["api", "jobs"],
              "query": [
                { "key": "location", "value": "Mumbai" },
                { "key": "search", "value": "mason" },
                { "key": "salaryType", "value": "daily" },
                { "key": "sort", "value": "highestSalary", "description": "oldest | highestSalary | lowestSalary" }
              ]
            }
          }
        },
        {
          "name": "Get Applied Jobs",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/jobs/getAppliedJobs", "host": ["{{baseUrl}}"], "path": ["api", "jobs", "getAppliedJobs"] } }
        },
        {
          "name": "Get Job by ID",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/jobs/{{jobId}}", "host": ["{{baseUrl}}"], "path": ["api", "jobs", "{{jobId}}"] } }
        },
        {
          "name": "Create Job",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) {",
                  "  pm.collectionVariables.set('jobId', res.data._id);",
                  "  pm.test('jobId stored', () => pm.expect(res.data._id).to.be.a('string'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/jobs", "host": ["{{baseUrl}}"], "path": ["api", "jobs"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Mason Required\",\n  \"company\": \"BuildRight\",\n  \"location\": \"Mumbai\",\n  \"latitude\": \"19.07\",\n  \"longitude\": \"72.87\",\n  \"quantity\": \"3\",\n  \"salary\": 900,\n  \"salaryType\": \"daily\",\n  \"isUrgent\": true,\n  \"duration\": \"15 days\",\n  \"description\": \"Experienced masons for a residential site\",\n  \"experience\": \"3\",\n  \"amenities\": []\n}" },
            "description": "Private. Vendor/admin, verified account only. Saves the new job's id into {{jobId}} for the requests below."
          }
        },
        {
          "name": "Apply to Job",
          "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/api/jobs/{{jobId}}/apply", "host": ["{{baseUrl}}"], "path": ["api", "jobs", "{{jobId}}", "apply"] }, "description": "Private. Verified workers only." }
        },
        {
          "name": "Like / Unlike Job",
          "request": { "method": "PUT", "url": { "raw": "{{baseUrl}}/api/jobs/{{jobId}}/like", "host": ["{{baseUrl}}"], "path": ["api", "jobs", "{{jobId}}", "like"] } }
        },
        {
          "name": "Add Job Comment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) pm.collectionVariables.set('commentId', res.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/jobs/{{jobId}}/comments", "host": ["{{baseUrl}}"], "path": ["api", "jobs", "{{jobId}}", "comments"] },
            "body": { "mode": "raw", "raw": "{\n  \"comment\": \"Is accommodation provided?\",\n  \"parentComment\": null\n}" },
            "description": "Saves the new comment's id into {{commentId}}."
          }
        },
        {
          "name": "Get Job Comments",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/jobs/{{jobId}}/comments?page=1&limit=10&sortBy=newest", "host": ["{{baseUrl}}"], "path": ["api", "jobs", "{{jobId}}", "comments"], "query": [ { "key": "page", "value": "1" }, { "key": "limit", "value": "10" }, { "key": "sortBy", "value": "newest", "description": "newest | oldest | popular" } ] }
          }
        },
        {
          "name": "Update Job Comment",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/jobs/{{jobId}}/comments/{{commentId}}", "host": ["{{baseUrl}}"], "path": ["api", "jobs", "{{jobId}}", "comments", "{{commentId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"comment\": \"Updated question\"\n}" }
          }
        },
        {
          "name": "Delete Job Comment",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/jobs/{{jobId}}/comments/{{commentId}}", "host": ["{{baseUrl}}"], "path": ["api", "jobs", "{{jobId}}", "comments", "{{commentId}}"] } }
        },
        {
          "name": "Delete Job",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/jobs/{{jobId}}", "host": ["{{baseUrl}}"], "path": ["api", "jobs", "{{jobId}}"] }, "description": "Owner or admin only." }
        }
      ]
    },
    {
      "name": "4. Community",
      "item": [
        {
          "name": "Get Community Feed",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/community/feed?page=1&limit=10", "host": ["{{baseUrl}}"], "path": ["api", "community", "feed"], "query": [ { "key": "page", "value": "1" }, { "key": "limit", "value": "10" } ] } }
        },
        {
          "name": "Create Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) pm.collectionVariables.set('postId', res.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/community/posts", "host": ["{{baseUrl}}"], "path": ["api", "community", "posts"] },
            "body": { "mode": "formdata", "formdata": [ { "key": "content", "value": "Finished a great project today!", "type": "text" }, { "key": "feeling", "value": "proud", "type": "text" }, { "key": "images", "type": "file", "src": [] }, { "key": "video", "type": "file", "src": [] } ] },
            "description": "Saves the new post's id into {{postId}}. Up to 5 images + 1 video."
          }
        },
        {
          "name": "Like / Unlike Post",
          "request": { "method": "PUT", "url": { "raw": "{{baseUrl}}/api/community/posts/{{postId}}/like", "host": ["{{baseUrl}}"], "path": ["api", "community", "posts", "{{postId}}", "like"] } }
        },
        {
          "name": "Add Post Comment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) pm.collectionVariables.set('commentId', res.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/community/posts/{{postId}}/comments", "host": ["{{baseUrl}}"], "path": ["api", "community", "posts", "{{postId}}", "comments"] },
            "body": { "mode": "raw", "raw": "{\n  \"comment\": \"Congrats!\",\n  \"parentComment\": null\n}" }
          }
        },
        {
          "name": "Get Post Comments",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/community/posts/{{postId}}/comments?page=1&limit=10&sortBy=newest", "host": ["{{baseUrl}}"], "path": ["api", "community", "posts", "{{postId}}", "comments"], "query": [ { "key": "page", "value": "1" }, { "key": "limit", "value": "10" }, { "key": "sortBy", "value": "newest" } ] } }
        },
        {
          "name": "Update Post Comment",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/community/posts/{{postId}}/comments/{{commentId}}", "host": ["{{baseUrl}}"], "path": ["api", "community", "posts", "{{postId}}", "comments", "{{commentId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"comment\": \"Edited comment\"\n}" }
          }
        },
        {
          "name": "Delete Post Comment",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/community/posts/{{postId}}/comments/{{commentId}}", "host": ["{{baseUrl}}"], "path": ["api", "community", "posts", "{{postId}}", "comments", "{{commentId}}"] } }
        },
        {
          "name": "Delete Post",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/community/posts/{{postId}}", "host": ["{{baseUrl}}"], "path": ["api", "community", "posts", "{{postId}}"] }, "description": "Owner or admin only." }
        }
      ]
    },
    {
      "name": "5. Amenities",
      "item": [
        {
          "name": "Get All Amenities",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/amenities", "host": ["{{baseUrl}}"], "path": ["api", "amenities"] } }
        },
        {
          "name": "Get Grouped Amenities",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/amenities/grouped", "host": ["{{baseUrl}}"], "path": ["api", "amenities", "grouped"] }, "description": "Amenities grouped by category, for building a picker UI." }
        },
        {
          "name": "Get All Categories",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/amenities/categories", "host": ["{{baseUrl}}"], "path": ["api", "amenities", "categories"] } }
        },
        {
          "name": "Add Amenity",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/amenities", "host": ["{{baseUrl}}"], "path": ["api", "amenities"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Provident Fund\",\n  \"category\": \"Financial Benefits\"\n}" },
            "description": "Vendor/Admin only (workers and customers are rejected). category must be one of: Financial Benefits, Accommodation & Food, Travel, Safety & Medical, Leave, Work & Career, Employee Rewards."
          }
        },
        {
          "name": "Update Amenity",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/amenities/:id", "host": ["{{baseUrl}}"], "path": ["api", "amenities", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Provident Fund (PF)\"\n}" },
            "description": "Admin only. `:id` is the Amenity's Mongo _id (from Get All Amenities)."
          }
        },
        {
          "name": "Delete Amenity",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/amenities/:id", "host": ["{{baseUrl}}"], "path": ["api", "amenities", ":id"], "variable": [{ "key": "id", "value": "" }] },
            "description": "Admin only. Fails with 400 if the amenity is still used by a job."
          }
        }
      ]
    },
    {
      "name": "6. Plans",
      "item": [
        {
          "name": "Get Plans",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/plans/plans", "host": ["{{baseUrl}}"], "path": ["api", "plans", "plans"] } }
        },
        {
          "name": "Create Plan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) pm.collectionVariables.set('planId', res.data._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/plans/plans", "host": ["{{baseUrl}}"], "path": ["api", "plans", "plans"] },
            "body": { "mode": "raw", "raw": "{\n  \"planName\": \"Vendor Premium\",\n  \"userType\": \"vendor\",\n  \"planType\": \"premium\",\n  \"frequency\": \"monthly\",\n  \"amount\": 4999,\n  \"features\": [\"Unlimited posts\", \"Priority support\"]\n}" },
            "description": "WARNING: currently any authenticated user can create plans — no admin check (see docs/AUDIT.md). Saves the new plan's id into {{planId}}."
          }
        },
        {
          "name": "Edit Plan",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/plans/plans/{{planId}}", "host": ["{{baseUrl}}"], "path": ["api", "plans", "plans", "{{planId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 3999\n}" }
          }
        },
        {
          "name": "Delete Plan",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/plans/plans/{{planId}}", "host": ["{{baseUrl}}"], "path": ["api", "plans", "plans", "{{planId}}"] } }
        }
      ]
    },
    {
      "name": "7. Legal",
