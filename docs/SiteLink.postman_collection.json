            "body": { "mode": "raw", "raw": "{\n  \"fcmToken\": \"<device-fcm-token>\"\n}" },
            "description": "Saves the FCM token for the currently authenticated user (req.user.id) — no userId needed in the body."
          }
        },
        {
          "name": "Send Push Notification",
