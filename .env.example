# ------------------------------------------------------------------
# SiteLink Backend — Environment Variables (template)
# Copy to `.env` and fill real values. NEVER commit the real .env.
# ------------------------------------------------------------------

# Server
NODE_ENV=development            # development | production
PORT=5000

# Database
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

# JWT
JWT_SECRET=<generate-a-long-random-string-min-32-chars>
JWT_EXPIRE=7d                   # e.g. 15m for access tokens (see audit: shorten this)

# Cloudinary (media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Admin (Google auth + push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full key. Keep the literal \n escapes; config/firebase.js converts them.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Recommended additions (not yet used by code — see audit) ----
# CORS_ORIGINS=https://app.sitelink.com,https://admin.sitelink.com
# SMS_PROVIDER_KEY=            # real OTP delivery (Twilio/MSG91/etc.)
